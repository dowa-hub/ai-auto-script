# STT Mode: "offline" (default, free) or "cloud" (Deepgram)
STT_MODE=offline

# Whisper model size: tiny.en / base.en / small.en / medium.en
# tiny = fastest (~39MB), base = balanced (~150MB), small = better (~500MB)
WHISPER_MODEL=base.en

# Deepgram API key (only needed if STT_MODE=cloud)
DEEPGRAM_API_KEY=

# Claude API key (used as fallback for hard jumps/paraphrasing)
# Leave blank to disable the Claude fallback
ANTHROPIC_API_KEY=
